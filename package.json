{
  "name": "@journiful/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm docker:up && turbo run dev",
    "dev:web": "turbo run dev --filter=@journiful/web",
    "dev:api": "turbo run dev --filter=@journiful/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@journiful/web",
    "build:api": "turbo run build --filter=@journiful/api",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "pnpm --filter=@journiful/web test:e2e",
    "test:e2e:ui": "pnpm --filter=@journiful/web test:e2e:ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:up": "docker-compose up -d postgres minio minio-init",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose up -d postgres minio minio-init",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "turbo": "^2.8.20",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "minimatch": ">=10.2.3",
      "esbuild": ">=0.25.0",
      "ajv@>=8": ">=8.18.0",
      "rollup": ">=4.59.0",
      "flatted": ">=3.4.2",
      "undici": ">=7.24.0",
      "fast-xml-parser": ">=5.5.6"
    }
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
